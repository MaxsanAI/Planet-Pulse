---
const { article } = Astro.props;
---

<article class="news-card">
  <div class="date">
    <span data-date={article.date} class="date-text">
      {new Date(article.date).toLocaleString()}
    </span>
  </div>

  <h2 class="title">
    {article.title}
  </h2>

  <p class="description">
    {
      article.description.length > 220
        ? article.description.slice(0, 220) + "..."
        : article.description
    }
  </p>

  <div class="actions">
    <button
      class="ai-button"
      data-title={article.safeTitle}
      data-desc={article.safeDescription}
      onclick="openAiModal(this.dataset.title,this.dataset.desc)"
    >
      ✨ AI Summary
    </button>

    <a
      href={article.link}
      target="_blank"
      rel="noopener noreferrer"
      class="source-link"
    >
      Read Source →
    </a>
  </div>
</article>

<style>
.news-card {
  background: #171b22;
  border: 1px solid #242a34;
  border-radius: 22px;
  padding: 22px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
  min-height: 260px;
}

.news-card:hover {
  transform: translateY(-4px);
  border-color: #3a4351;
  box-shadow: 0 15px 40px rgba(0,0,0,.45);
}

.date {
  color: #8b96a7;
  font-size: .85rem;
}

.title {
  margin: 0;
  color: white;
  line-height: 1.4;
  font-size: 1.15rem;
  font-weight: 700;
}

.description {
  margin: 0;
  color: #c1c8d4;
  line-height: 1.7;
  flex: 1;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: auto;
}

.ai-button {
  border: none;
  cursor: pointer;
  border-radius: 12px;
  padding: 12px 16px;
  background: linear-gradient(135deg, #6d5dfc, #8c7bff);
  color: white;
  font-weight: 700;
  transition: .2s;
}

.ai-button:hover {
  transform: translateY(-2px);
}

.source-link {
  text-decoration: none;
  color: #7eb6ff;
  border: 1px solid #2c3644;
  border-radius: 12px;
  padding: 12px 16px;
  transition: .2s;
}

.source-link:hover {
  background: #202733;
  border-color: #425067;
}

@media (max-width: 768px) {
  .news-card {
    padding: 18px;
  }

  .title {
    font-size: 1rem;
  }

  .actions {
    flex-direction: column;
  }

  .actions a,
  .actions button {
    width: 100%;
  }
}
</style>
